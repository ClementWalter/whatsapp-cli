#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# # Exact pins — match pyproject.toml. Supply-chain defense: a compromised
# # new release can't sneak in via `>=` resolution. Bump deliberately.
# dependencies = [
#     "aiohttp==3.13.5",
#     "click==8.3.3",
#     "cryptography==48.0.0",
#     "protobuf==7.34.1",
#     "qrcode[pil]==8.2",
#     "signal-protocol==0.2.2",
#     "pyobjc-framework-Contacts==12.1; sys_platform == 'darwin'",
# ]
# ///
"""Standalone launcher for the WhatsApp CLI.

PEP 723 inline metadata makes ``bin/wa`` runnable directly via ``uv run``
without installing the package — used both for fresh checkouts and for
skill-bundle delivery (the SKILL.md tells agents to invoke this file
relative to the skill root). The real CLI lives in ``wa.cli``.
"""

from __future__ import annotations

import sys
from pathlib import Path

# Add the repo root to sys.path so the sibling `wa/` package is importable
# when this file is executed directly (not installed as a console script).
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from wa.cli import cli

if __name__ == "__main__":
    cli()
